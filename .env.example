# ===== Base de datos PostgreSQL =====
# En Railway se crea sola al agregar el plugin PostgreSQL (referenciá ${{Postgres.DATABASE_URL}}).
DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Poné true solo si conectás por la URL pública (no la interna de Railway).
DATABASE_SSL=false

# ===== Panel admin =====
ADMIN_PASSWORD=cambiala-por-una-segura
# Secreto para firmar la cookie de sesión (cualquier string largo y aleatorio).
SESSION_SECRET=pon-aca-un-string-aleatorio-largo

# ===== Cloudflare R2 (almacenamiento de imágenes) =====
R2_ACCOUNT_ID=tu-account-id-de-cloudflare
R2_ACCESS_KEY_ID=tu-access-key
R2_SECRET_ACCESS_KEY=tu-secret-key
R2_BUCKET=nombre-del-bucket
# URL pública del bucket (dominio r2.dev o tu dominio propio), SIN barra final.
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
